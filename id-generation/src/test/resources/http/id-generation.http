### ID Generation API Test
### IntelliJ HTTP Client 기반 테스트 파일

### ============================================
### 1. 배치 ID 삽입 (100,000건 Base33 랜덤 값 사전 적재)
### ============================================
POST http://localhost:8080/api/v1/id-generation/batch
Content-Type: application/json

> {%
    client.test("배치 ID 삽입 성공", function () {
        client.assert(response.status === 200, "Status is 200");
        client.assert(response.body.header.isSuccessful === true, "isSuccessful is true");
    });
%}

### ============================================
### 2. ID 타입 등록 - AGENT (AG)
### ============================================
POST http://localhost:8080/api/v1/id-generation/types/AG
Content-Type: application/json

> {%
    client.test("AG 타입 등록 성공", function () {
        client.assert(response.status === 200, "Status is 200");
        client.assert(response.body.header.isSuccessful === true, "isSuccessful is true");
    });
%}

### ============================================
### 3. ID 타입 등록 - BACKUP (MB)
### ============================================
POST http://localhost:8080/api/v1/id-generation/types/MB
Content-Type: application/json

> {%
    client.test("MB 타입 등록 성공", function () {
        client.assert(response.status === 200, "Status is 200");
        client.assert(response.body.header.isSuccessful === true, "isSuccessful is true");
    });
%}

### ============================================
### 4. ID 생성 - AGENT 타입
### ============================================
POST http://localhost:8080/api/v1/id-generation/AG
Content-Type: application/json

> {%
    client.test("AG ID 생성 성공", function () {
        client.assert(response.status === 200, "Status is 200");
        client.assert(response.body.header.isSuccessful === true, "isSuccessful is true");
        client.assert(response.body.data.startsWith("AG-"), "ID starts with AG-");
        client.log("Generated ID: " + response.body.data);
    });
%}

### ============================================
### 5. ID 생성 - BACKUP 타입
### ============================================
POST http://localhost:8080/api/v1/id-generation/MB
Content-Type: application/json

> {%
    client.test("MB ID 생성 성공", function () {
        client.assert(response.status === 200, "Status is 200");
        client.assert(response.body.header.isSuccessful === true, "isSuccessful is true");
        client.assert(response.body.data.startsWith("MB-"), "ID starts with MB-");
        client.log("Generated ID: " + response.body.data);
    });
%}

