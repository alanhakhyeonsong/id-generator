### ============================================
### 7. 존재하지 않는 타입으로 ID 생성 (에러 케이스)
### ============================================
POST http://localhost:8080/api/v1/id-generation/XX
Content-Type: application/json

> {%
    client.test("존재하지 않는 타입 - 에러 응답", function () {
        client.assert(response.status !== 200, "Status is not 200");
        client.assert(response.body.header.isSuccessful === false, "isSuccessful is false");
        client.log("Error: " + response.body.header.message);
    });
%}

### ============================================
### 8. 잘못된 HTTP 메서드 (에러 케이스)
### ============================================
GET http://localhost:8080/api/v1/id-generation/AG

> {%
    client.test("GET 메서드 - 405 에러", function () {
        client.assert(response.status === 405, "Status is 405");
    });
%}

### ============================================
### 9. 존재하지 않는 경로 (에러 케이스)
### ============================================
POST http://localhost:8080/api/v1/not-exists
Content-Type: application/json

> {%
    client.test("존재하지 않는 경로 - 404 에러", function () {
        client.assert(response.status === 404, "Status is 404");
    });
%}

